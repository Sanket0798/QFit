# API Configuration
VITE_API_BASE_URL=http://localhost:3000/api
VITE_API_TIMEOUT=30000

# Authentication
VITE_AUTH_TOKEN_KEY=qfit_auth_token
VITE_REFRESH_TOKEN_KEY=qfit_refresh_token

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_CHAT_SUPPORT=false

# Environment
VITE_ENV=development

# App Configuration
VITE_APP_NAME=QFit
VITE_APP_VERSION=1.0.0
